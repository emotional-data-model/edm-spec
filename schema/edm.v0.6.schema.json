{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://deepadata.com/schemas/edm/v0.6.0/edm.schema.json",
  "title": "Emotional Data Model (EDM) v0.6.0",
  "description": "A protocol-level representation and persistence architecture for governed emotional data. EDM v0.6.0 defines a domain-complete manifold for encoding affective context as a stable, machine-interpretable, and sovereignty-preserving data object.",
  "type": "object",
  "required": [
    "meta"
  ],
  "properties": {
    "meta": {
      "description": "Identity, provenance, and consent metadata. Establishes artifact origin, ownership, and legal basis.",
      "type": "object",
      "required": [
        "version",
        "profile",
        "created_at",
        "visibility",
        "pii_tier",
        "consent_basis"
      ],
      "properties": {
        "id": {
          "type": [
            "string",
            "null"
          ],
          "description": "Unique identifier for the EDM artifact. Required for provenance, linking, auditing, and .ddna envelope binding.",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        },
        "version": {
          "type": "string",
          "description": "Declares which EDM schema this artifact conforms to and enables safe validation and migration.",
          "pattern": "^0\\.6\\.[0-9]+$"
        },
        "profile": {
          "type": "string",
          "enum": [
            "essential",
            "extended",
            "full"
          ],
          "description": "Implementation profile declaration. Determines required domains per EDM v0.6.0 Section 3.7."
        },
        "created_at": {
          "type": "string",
          "description": "Marks when the artifact was extracted. Anchors temporal provenance.",
          "format": "date-time"
        },
        "updated_at": {
          "type": [
            "string",
            "null"
          ],
          "description": "Optional timestamp for post-extraction updates.",
          "format": "date-time"
        },
        "locale": {
          "type": [
            "string",
            "null"
          ],
          "description": "Linguistic and cultural context of the source content.",
          "pattern": "^[a-z]{2}(-[a-z]{2})?$"
        },
        "owner_user_id": {
          "type": [
            "string",
            "null"
          ],
          "description": "The artifact owner identifier."
        },
        "parent_id": {
          "type": [
            "string",
            "null"
          ],
          "description": "Links this artifact to its parent.",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        },
        "visibility": {
          "type": "string",
          "description": "Determines who may view or process the artifact.",
          "enum": [
            "private",
            "shared",
            "public"
          ]
        },
        "pii_tier": {
          "type": "string",
          "description": "Classification of personal or sensitive content.",
          "enum": [
            "none",
            "low",
            "moderate",
            "high",
            "extreme"
          ]
        },
        "source_type": {
          "type": [
            "string",
            "null"
          ],
          "description": "The medium from which the artifact was extracted.",
          "enum": [
            "text",
            "audio",
            "image",
            "video",
            "mixed",
            null
          ]
        },
        "source_context": {
          "type": [
            "string",
            "null"
          ],
          "description": "Optional narrative describing the input scenario."
        },
        "consent_basis": {
          "type": "string",
          "description": "Legal basis for storing and processing emotional data.",
          "enum": [
            "consent",
            "contract",
            "legitimate_interest",
            "none"
          ]
        },
        "consent_scope": {
          "type": [
            "string",
            "null"
          ],
          "description": "What the user consented to."
        },
        "consent_revoked_at": {
          "type": [
            "string",
            "null"
          ],
          "description": "If populated, artifact becomes non-retrievable.",
          "format": "date-time"
        },
        "tags": {
          "type": [
            "array",
            "null"
          ],
          "description": "Optional user-defined labels.",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "core": {
      "$ref": "fragments/core.json"
    },
    "constellation": {
      "$ref": "fragments/constellation.json"
    },
    "milky_way": {
      "$ref": "fragments/milky_way.json"
    },
    "gravity": {
      "$ref": "fragments/gravity.json"
    },
    "impulse": {
      "$ref": "fragments/impulse.json"
    },
    "governance": {
      "$ref": "fragments/governance.json"
    },
    "telemetry": {
      "$ref": "fragments/telemetry.json"
    },
    "system": {
      "$ref": "fragments/system.json"
    },
    "crosswalks": {
      "$ref": "fragments/crosswalks.json"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "meta": {
            "properties": {
              "profile": {
                "const": "essential"
              }
            }
          }
        }
      },
      "then": {
        "required": [
          "meta",
          "core",
          "constellation",
          "governance",
          "telemetry"
        ],
        "propertyNames": {
          "enum": [
            "meta",
            "core",
            "constellation",
            "governance",
            "telemetry"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "meta": {
            "properties": {
              "profile": {
                "const": "extended"
              }
            }
          }
        }
      },
      "then": {
        "required": [
          "meta",
          "core",
          "constellation",
          "milky_way",
          "gravity",
          "governance",
          "telemetry"
        ],
        "propertyNames": {
          "enum": [
            "meta",
            "core",
            "constellation",
            "milky_way",
            "gravity",
            "governance",
            "telemetry"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "meta": {
            "properties": {
              "profile": {
                "const": "full"
              }
            }
          }
        }
      },
      "then": {
        "required": [
          "meta",
          "core",
          "constellation",
          "milky_way",
          "gravity",
          "impulse",
          "governance",
          "telemetry",
          "system",
          "crosswalks"
        ],
        "propertyNames": {
          "enum": [
            "meta",
            "core",
            "constellation",
            "milky_way",
            "gravity",
            "impulse",
            "governance",
            "telemetry",
            "system",
            "crosswalks"
          ]
        }
      }
    }
  ],
  "definitions": {
    "version_info": {
      "version": "0.6.0",
      "released": "2026-03-08",
      "status": "stable",
      "changes_from_v05": [
        "Added meta.profile field for implementation profile declaration",
        "Profile-based conditional validation: artifacts must contain exactly the domains for their declared profile"
      ]
    }
  }
}